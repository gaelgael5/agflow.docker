# ───────────────────────────────────────────────────────────────────
# En production Docker Swarm, les variables ci-dessous (secrets) sont
# lues depuis /run/secrets/<nom_lowercase> via Pydantic Settings
# secrets_dir + le helper agflow.utils.swarm_secrets. En développement
# local, elles sont lues depuis ce fichier .env directement.
#
# Mapping nom_env → nom_secret_swarm (lowercase) :
#   DATABASE_URL          → /run/secrets/database_url
#   JWT_SECRET            → /run/secrets/jwt_secret
#   HARPOCRATE_KEY        → /run/secrets/harpocrate_key
#   HARPOCRATE_URL        → /run/secrets/harpocrate_url
#   ADMIN_PASSWORD_HASH   → /run/secrets/admin_password_hash
#   API_KEY_SALT          → /run/secrets/api_key_salt
#   GOOGLE_CLIENT_SECRET  → /run/secrets/google_client_secret
#
# La clé SSH backend (terminal.py) :
#   /app/.ssh/backend_key (compose actuel) → /run/secrets/agflow_backend_key (Swarm)
# ───────────────────────────────────────────────────────────────────

# ─── Database ───
DATABASE_URL=postgresql://agflow:REPLACE_ME_WITH_STRONG_PASSWORD@postgres:5432/agflow
POSTGRES_USER=agflow
POSTGRES_PASSWORD=REPLACE_ME_WITH_STRONG_PASSWORD
POSTGRES_DB=agflow


# ─── Redis ───
REDIS_URL=redis://redis:6379/0


# ─── Admin auth ───
# Generate hash with:
#   uv run python -c "import bcrypt; print(bcrypt.hashpw(b'your-password', bcrypt.gensalt()).decode())"
ADMIN_EMAIL=admin@agflow.example.com
ADMIN_PASSWORD_HASH=REPLACEMEWITHREALBCRYPTHASH

# ─── JWT ───
# Generate with:
#   uv run python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=REPLACE_ME_WITH_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS
JWT_EXPIRE_HOURS=24

# ─── Harpocrate vault — bootstrap legacy ───
# Les coffres Harpocrate sont désormais configurés côté DB (table
# harpocrate_vaults) via la page /settings → onglet Harpocrate. Ces 3 vars
# servent uniquement de FALLBACK quand la DB ne contient aucun coffre
# (bootstrap initial). Une fois un coffre créé en DB, ces valeurs sont
# ignorées par vault_client.
# Dev local : https://192.168.10.123:8443 (cert auto-signé, HARPOCRATE_ALLOW_INSECURE=1)
# Prod : https://vault.yoops.org
HARPOCRATE_KEY=hrpv_1_REPLACE_ME
HARPOCRATE_URL=https://vault.yoops.org
# HARPOCRATE_ALLOW_INSECURE=1  # dev uniquement (certificat auto-signé)
# Identifiant de l'API key Harpocrate utilisée pour les connexions distantes.
HARPOCRATE_VAULT_API_KEY_ID=default

# Data Encryption Key — passphrase pgcrypto utilisée pour chiffrer la colonne
# `harpocrate_vaults.api_key_encrypted`. Doit être identique sur tous les
# nœuds qui partagent la même base. Générer avec :
#   uv run python -c "import secrets; print(secrets.token_urlsafe(48))"
HARPOCRATE_DEK=REPLACE_ME_WITH_LONG_RANDOM_STRING

# ─── API Key Salt ───
# Used to hash API keys before storage.
# Generate with:
#   uv run python -c "import secrets; print(secrets.token_urlsafe(32))"
# Important: changing this will invalidate all existing API keys, as their hashes won't match anymore.
API_KEY_SALT=2af3cfe6725d11505590fb5772e3efb7999fa9f3

# ─── App ───
ENVIRONMENT=dev
LOG_LEVEL=INFO


# Répertoire local pour les backups sur disque (monté en volume Docker).
AGFLOW_DATA_DIR=/app/data