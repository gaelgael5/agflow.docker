{
  "title": "Systemd / Journald — Vue d'ensemble",
  "uid": "agflow-journald",
  "tags": ["systemd", "journald", "agflow"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "host",
        "label": "Hôte LXC",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values({job=\"systemd-journal\"}, host)",
        "refresh": 2,
        "includeAll": true,
        "multi": true
      },
      {
        "name": "unit",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values({job=\"systemd-journal\", host=~\"$host\"}, unit)",
        "refresh": 2,
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "logs",
      "title": "Logs systemd",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 0 },
      "options": {
        "showLabels": true,
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "{job=\"systemd-journal\", host=~\"$host\", unit=~\"$unit\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Top services (lignes/min)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "topk(10, sum by (unit) (count_over_time({job=\"systemd-journal\", host=~\"$host\"}[1m])))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Niveaux d'erreur par hôte",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum by (host) (count_over_time({job=\"systemd-journal\"} |~ \"(?i)(error|fail|critical)\"[1m]))",
          "refId": "A"
        }
      ]
    }
  ]
}
