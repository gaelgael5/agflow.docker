{
  "args": [
    {
      "arg": "LXC_ID",
      "label_fr": "Identifiant LXC (CT ID)",
      "description_fr": "Numéro unique du container (ex: 200, 201…)",
      "type": "string",
      "required": true
    },
    {
      "arg": "LXC_NAME",
      "label_fr": "Nom du container",
      "description_fr": "Hostname du container LXC (ex: agflow-docker-test)",
      "type": "string",
      "required": false
    }
  ],
  "command": "wget -qO /tmp/agflow-create-lxc.sh https://raw.githubusercontent.com/gaelgael5/agflow.docker/refs/heads/main/scripts/infra/00-create-lxc.sh && bash /tmp/agflow-create-lxc.sh {LXC_ID} {LXC_NAME}"
}
